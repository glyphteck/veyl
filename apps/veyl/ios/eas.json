{
    "cli": {
        "version": ">= 16.0.1",
        "appVersionSource": "remote"
    },
    "build": {
        "development": {
            "developmentClient": true,
            "distribution": "internal"
        },
        "preview": {
            "distribution": "internal"
        },
        "local": {
            "distribution": "internal",
            "env": {
                "VEYL_IOS_VARIANT": "local",
                "EXPO_PUBLIC_NETWORK": "REGTEST"
            }
        },
        "production": {
            "autoIncrement": true,
            "env": {
                "VEYL_IOS_VARIANT": "prod",
                "EXPO_PUBLIC_NETWORK": "MAINNET"
            }
        }
    },
    "submit": {
        "production": {
            "ios": {
                "appleTeamId": "HHTM355M49",
                "bundleIdentifier": "com.glyphteck.veyl",
                "sku": "com.glyphteck.veyl",
                "language": "en-US",
                "companyName": "Glyphteck Corp",
                "appName": "veyl"
            }
        }
    }
}
