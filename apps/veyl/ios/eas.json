{
    "cli": {
        "version": ">= 8.0.0"
    },
    "build": {
        "development": {
            "developmentClient": true,
            "distribution": "internal"
        },
        "preview": {
            "distribution": "internal"
        },
        "local": {
            "distribution": "internal",
            "env": {
                "VEYL_IOS_VARIANT": "local",
                "EXPO_PUBLIC_NETWORK": "REGTEST"
            }
        },
        "production": {
            "env": {
                "EXPO_PUBLIC_NETWORK": "MAINNET"
            }
        }
    }
}
