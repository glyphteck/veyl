{
    "name": "veyl",
    "version": "4.6.5",
    "private": true,
    "workspaces": {
        "packages": [
            "apps/*",
            "apps/veyl/*",
            "shared"
        ],
        "catalog": {
            "@buildonspark/spark-sdk": "^0.8.0",
            "@noble/ciphers": "^2.2.0",
            "@noble/curves": "^2.2.0",
            "@noble/hashes": "^2.2.0",
            "@scure/bip39": "^2.2.0",
            "@tailwindcss/postcss": "^4.3.0",
            "bech32": "^2.0.0",
            "firebase": "^12.13.0",
            "lucide-react": "^1.14.0",
            "next": "^16.2.6",
            "next-themes": "^0.4.6",
            "postcss": "^8.5.14",
            "react": "19.2.0",
            "react-dom": "19.2.0",
            "sonner": "^2.0.7",
            "tailwindcss": "^4.3.0",
            "tw-animate-css": "^1.4.0"
        }
    },
    "scripts": {
        "admin": "node scripts/admin/index.mjs",
        "bot": "node scripts/admin/bot.mjs",
        "push": "node scripts/repo.mjs push",
        "merge": "node scripts/repo.mjs merge",
        "veyl": "node scripts/veyl.mjs",
        "make": "node scripts/build.mjs",
        "ban": "node scripts/admin/ban.mjs",
        "nuke": "node scripts/admin/nuke.mjs",
        "steal": "node scripts/admin/steal.mjs",
        "lint": "eslint . --quiet",
        "lint:warn": "eslint .",
        "lint:fix": "eslint . --fix",
        "update": "bun update --recursive && bun sync:frameworks",
        "sync:frameworks": "node scripts/sync-frameworks.mjs",
        "check:frameworks": "node scripts/sync-frameworks.mjs --check"
    },
    "dependencies": {
        "@buildonspark/spark-sdk": "^0.8.0",
        "@noble/ciphers": "catalog:",
        "@noble/curves": "catalog:",
        "@noble/hashes": "catalog:",
        "@scure/bip39": "catalog:",
        "bech32": "catalog:",
        "firebase": "catalog:"
    },
    "overrides": {
        "firebase": "catalog:",
        "next": "catalog:"
    },
    "patchedDependencies": {
        "@noble/hashes@1.8.0": "patches/@noble__hashes@1.8.0.patch",
        "react-native-argon2@4.0.0": "patches/react-native-argon2@4.0.0.patch"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "eslint": "^10.3.0",
        "eslint-plugin-react-hooks": "^7.1.1",
        "globals": "^17.6.0"
    }
}
