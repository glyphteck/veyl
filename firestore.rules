rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* ---------- helpers ---------- */
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    function mapGet(m, k) {
      return m is map && k in m ? m[k] : null;
    }

    function activeBanData(data, key) {
      let banned = mapGet(data, 'banned');
      let ban = mapGet(banned, key);
      let until = mapGet(ban, 'until');
      return ban is map
        && (
          until == null
          || (until is timestamp && until > request.time)
        );
    }

    function activeBan(uid, key) {
      let data = uid is string && exists(/databases/$(database)/documents/moderation/$(uid))
        ? get(/databases/$(database)/documents/moderation/$(uid)).data
        : {};
      return activeBanData(data, key);
    }

    function profileAvatarValueAllowed(value) {
      return value == null || (value is int && value > 0);
    }

    function profileAvatarUpdateAllowed(uid) {
      let nextAvatar = mapGet(request.resource.data, 'avatar');
      return 'avatar' in request.resource.data
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['avatar'])
        && profileAvatarValueAllowed(nextAvatar)
        && (
          nextAvatar == null
          || (!activeBan(uid, 'full') && !activeBan(uid, 'avatar'))
        );
    }

    function ttlValueAllowed(value) {
      return value == null || value is timestamp;
    }

    function chatIdFormatAllowed(chatId) {
      return chatId is string
        && chatId.size() == 64
        && chatId.matches('^[0-9a-f]{64}$');
    }

    function chatDeleted(chatId) {
      return chatIdFormatAllowed(chatId)
        && exists(/databases/$(database)/documents/chats/$(chatId))
        && get(/databases/$(database)/documents/chats/$(chatId)).data.deleted is string;
    }

    function chatIdAllowed(chatId) {
      return request.auth != null
        && chatIdFormatAllowed(chatId)
        && !chatDeleted(chatId);
    }

    function maxInitialTtl() {
      return request.time + duration.value(21, 'd') + duration.value(10, 'm');
    }

    function messageBodyMaxBytes() {
      return 64 * 1024;
    }

    function bytesSizeAllowed(value, maxBytes) {
      return value is bytes && value.size() <= maxBytes;
    }

    function initialTtlValueAllowed(value) {
      return value is timestamp
        && value >= request.time
        && value <= maxInitialTtl();
    }

    function messageHeadValid(head) {
      return head is map
        && head.keys().hasOnly(['cid'])
        && mapGet(head, 'cid') is string
        && mapGet(head, 'cid').size() >= 1
        && mapGet(head, 'cid').size() <= 128;
    }

    function messageFieldsValid(data) {
      return data.keys().hasOnly(['head', 'body', 'ts', 'ttl'])
        && messageHeadValid(data.head)
        && bytesSizeAllowed(data.body, messageBodyMaxBytes())
        && data.ts is timestamp
        && 'ttl' in data
        && ttlValueAllowed(data.ttl);
    }

    function messageCreateAllowed() {
      return messageFieldsValid(request.resource.data)
        && request.resource.data.ts == request.time
        && (
          request.resource.data.ttl == null
          || initialTtlValueAllowed(request.resource.data.ttl)
        );
    }

    function messageTtlUpdateAllowed() {
      return messageFieldsValid(request.resource.data)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['ttl'])
        && (
          request.resource.data.ttl == null
          || initialTtlValueAllowed(request.resource.data.ttl)
        );
    }

    function ownerChatEntryValid(data) {
      return data.keys().hasOnly(['body', 'ts'])
        && bytesSizeAllowed(data.body, 128 * 1024)
        && data.ts is timestamp;
    }

    function communityRulesAckValid(data) {
      return data.communityRulesVersion is string
        && data.communityRulesVersion.size() >= 4
        && data.communityRulesVersion.size() <= 32
        && data.communityRulesDate is string
        && data.communityRulesDate.size() >= 4
        && data.communityRulesDate.size() <= 32
        && data.communityRulesAcceptedAt == request.time;
    }

    function settingsValid(data) {
      let settings = mapGet(data, 'settings');

      return bytesSizeAllowed(settings, 16 * 1024);
    }

    function communityRulesShapeValid(data) {
      let version = mapGet(data, 'communityRulesVersion');
      let date = mapGet(data, 'communityRulesDate');
      let acceptedAt = mapGet(data, 'communityRulesAcceptedAt');

      return (
          (version == null && date == null && acceptedAt == null)
          || (version is string && (date == null || date is string) && acceptedAt is timestamp)
        );
    }

    function userDocCreateValid(data) {
      return data.keys().hasOnly(['settings', 'communityRulesVersion', 'communityRulesDate', 'communityRulesAcceptedAt'])
        && (!('settings' in data) || settingsValid(data))
        && communityRulesShapeValid(data);
    }

    function userDocUpdateValid() {
      return request.resource.data.keys().hasOnly(['settings', 'communityRulesVersion', 'communityRulesDate', 'communityRulesAcceptedAt'])
        && (!('settings' in request.resource.data) || settingsValid(request.resource.data))
        && communityRulesShapeValid(request.resource.data)
        && (
          (
            mapGet(request.resource.data, 'communityRulesVersion') == mapGet(resource.data, 'communityRulesVersion')
            && mapGet(request.resource.data, 'communityRulesDate') == mapGet(resource.data, 'communityRulesDate')
            && mapGet(request.resource.data, 'communityRulesAcceptedAt') == mapGet(resource.data, 'communityRulesAcceptedAt')
          )
          || communityRulesAckValid(request.resource.data)
        );
    }

    /* ---------- users / profiles / misc ---------- */
    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow list: if false;
      allow create: if request.auth != null
                    && request.auth.uid == uid
                    && userDocCreateValid(request.resource.data)
                    && (
                      (!('communityRulesVersion' in request.resource.data) && !('communityRulesDate' in request.resource.data) && !('communityRulesAcceptedAt' in request.resource.data))
                      || communityRulesAckValid(request.resource.data)
                    );
      allow update: if request.auth != null
                    && request.auth.uid == uid
                    && userDocUpdateValid();
      allow write: if false;

      match /blocked/{peerUid} {
        allow get, list: if request.auth != null && request.auth.uid == uid;
        allow create, update: if request.auth != null
                              && request.auth.uid == uid
                              && peerUid != uid
                              && request.resource.data.keys().size() == 0;
        allow delete: if request.auth != null && request.auth.uid == uid;
      }

      match /chats/{entryId} {
        allow get, list: if request.auth != null && request.auth.uid == uid;
        allow create, update: if request.auth != null
                              && request.auth.uid == uid
                              && ownerChatEntryValid(request.resource.data);
        allow delete: if request.auth != null && request.auth.uid == uid;
      }

      match /inbox/{pingId} {
        allow get, list, delete: if request.auth != null && request.auth.uid == uid;
        allow create, update: if false;
      }

      match /push/{did} {
        allow read, write: if false;
      }
    }
    match /moderation/{uid} {
      allow get: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }
    match /admins/{uid} {
      allow get: if request.auth != null
                 && (request.auth.uid == uid || isAdmin());
      allow list: if isAdmin();
      allow write: if false;
    }
    match /runtimes/{id} {
      allow get: if isAdmin();
      allow write: if false;
    }
    match /bots/{uid} {
      allow get, list: if isAdmin();
      allow write: if false;

      match /events/{eventId} {
        allow get, list: if isAdmin();
        allow write: if false;
      }
    }
    match /reported/{uid} {
      allow get, list: if isAdmin();
      allow write: if false;

      match /reports/{reportId} {
        allow get, list: if isAdmin();
        allow write: if false;
      }
    }
    match /profiles/{uid} {
      allow get: if request.auth != null;
      allow list: if request.auth != null
                  && request.query.limit != null
                  && request.query.limit <= 15;
      // profiles are managed server-side, except for presence and the owner's avatar step state.
      allow create: if false;
      allow update: if request.auth != null
                    && request.auth.uid == uid
                    && (
                      (
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['active'])
                        && request.resource.data.active is bool
                      )
                      || profileAvatarUpdateAllowed(uid)
                    );
      allow delete: if false;
    }
    match /seeds/{uid} {
      allow get: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null
                    && request.auth.uid == uid
                    && request.resource.data.keys().hasOnly(['es']);
      allow list, update, delete: if false;
    }

    // bitcoin data
    match /bitcoin/current {
      allow get: if true;
      allow list: if false;
      allow write: if false;
    }

    //usernames
    match /usernames/{name} {
      allow get: if request.auth != null;
      allow list, create, update, delete: if false;
    }

    /* ---------- chats ---------- */
    match /links/{linkId} {
      allow read, write: if false;
    }

    match /chats/{chatId} {

      /* parent chat document */
      allow get: if request.auth != null
                 && chatIdFormatAllowed(chatId);
      allow list, create, update, delete: if false;

      /* messages sub-collection */
      match /messages/{messageId} {
        allow get, list: if chatIdAllowed(chatId);

        allow create: if chatIdAllowed(chatId)
                      && messageCreateAllowed();

        allow update: if chatIdAllowed(chatId)
                      && messageTtlUpdateAllowed();
        allow delete: if chatIdAllowed(chatId);
      }
    }

    /* block everything else */
    match /{document=**} { allow read, write: if false; }
  }
}
