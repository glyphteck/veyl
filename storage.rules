rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid));
    }

    function activeBan(ban) {
      return ban is map
        && (
          !('until' in ban)
          || ban.until == null
          || (ban.until is timestamp && ban.until > request.time)
        );
    }

    function isAvatarBanned(uid) {
      return uid is string
        && firestore.exists(/databases/(default)/documents/moderation/$(uid))
        && firestore.get(/databases/(default)/documents/moderation/$(uid)).data.banned is map
        && (
          activeBan(firestore.get(/databases/(default)/documents/moderation/$(uid)).data.banned.full)
          || activeBan(firestore.get(/databases/(default)/documents/moderation/$(uid)).data.banned.avatar)
        );
    }

    function isAvatarWrite() {
      return request.resource == null
        || (
          request.resource.size < 5 * 1024 * 1024
          && request.resource.contentType.matches('image/.*')
        );
    }

    function chatMediaReservationPath(mediaId) {
      return /databases/(default)/documents/media_upload_reservations/$(mediaId);
    }

    function isReservedChatBlob(mediaId) {
      let reservation = firestore.get(chatMediaReservationPath(mediaId)).data;
      return request.resource != null
        && firestore.exists(chatMediaReservationPath(mediaId))
        && reservation.uid == request.auth.uid
        && reservation.path == 'media/' + mediaId + '/main'
        && reservation.contentType == 'application/octet-stream'
        && reservation.ttl is timestamp
        && reservation.ttl > request.time
        && reservation.size is int
        && request.resource.size > 0
        && request.resource.size <= reservation.size
        && request.resource.size <= 20 * 1024 * 1024
        && request.resource.contentType == reservation.contentType;
    }

    function isReportBlob() {
      return request.resource != null
        && request.resource.size > 0
        && request.resource.size <= 20 * 1024 * 1024;
    }

    function isReportEvidenceId(value) {
      return value is string && value.matches('^[A-Za-z0-9_-]{8,80}$');
    }

    function reportEvidenceReservationPath(reporterUid, targetUid, evidenceId) {
      return /databases/(default)/documents/report_upload_reservations/$(reporterUid)/targets/$(targetUid)/report_upload_items/$(evidenceId);
    }

    function isReservedReportBlob(reporterUid, targetUid, evidenceId) {
      let reservation = firestore.get(reportEvidenceReservationPath(reporterUid, targetUid, evidenceId)).data;
      return firestore.exists(reportEvidenceReservationPath(reporterUid, targetUid, evidenceId))
        && reservation.uid == request.auth.uid
        && reservation.targetUid == targetUid
        && reservation.path == 'reports/' + reporterUid + '/' + targetUid + '/' + evidenceId
        && reservation.contentType is string
        && reservation.ttl is timestamp
        && reservation.ttl > request.time
        && reservation.size is int
        && isReportBlob()
        && request.resource.size <= reservation.size
        && request.resource.contentType == reservation.contentType;
    }

    match /{uid}/avatar.webp {
      allow read: if signedIn();
      allow write: if (
        isAdmin()
        && request.resource == null
      ) || (
        signedIn()
        && request.auth.uid == uid
        && !isAvatarBanned(uid)
        && isAvatarWrite()
      );
    }

    match /media/{mediaId}/{slot} {
      allow get: if signedIn();
      allow list: if false;
      allow create: if signedIn()
        && mediaId.matches('^[0-9a-fA-F]{32}$')
        && slot == 'main'
        && isReservedChatBlob(mediaId);
      allow update, delete: if false;
    }

    match /reports/{reporterUid}/{targetUid}/{evidenceId} {
      allow read: if isAdmin();
      allow create: if signedIn()
        && request.auth.uid == reporterUid
        && isReportEvidenceId(evidenceId)
        && isReservedReportBlob(reporterUid, targetUid, evidenceId);
      allow update, delete: if false;
    }
  }
}
