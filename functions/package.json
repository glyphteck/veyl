{
    "name": "functions",
    "description": "Cloud Functions for Firebase",
    "type": "module",
    "scripts": {
        "ban": "node ../scripts/admin/ban.mjs",
        "nuke": "node ../scripts/admin/nuke.mjs",
        "serve": "firebase emulators:start --only functions",
        "shell": "firebase functions:shell",
        "start": "npm run shell",
        "deploy": "firebase deploy --only functions",
        "logs": "firebase functions:log",
        "lint": "cd .. && bun x eslint functions --quiet"
    },
    "engines": {
        "node": "22"
    },
    "main": "index.js",
    "dependencies": {
        "@buildonspark/spark-sdk": "^0.8.0",
        "fido2-lib": "^3.5.9",
        "firebase-admin": "^13.9.0",
        "firebase-functions": "^7.2.5"
    },
    "devDependencies": {
        "firebase-functions-test": "^3.5.0"
    },
    "private": true
}
